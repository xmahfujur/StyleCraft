rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 0. Global safety net (Default Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // ===================================
    // GLOBAL HELPERS
    // ===================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email in ['samimolla629@gmail.com', 'mr074770@gmail.com'] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin')
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ===================================
    // VALIDATIONS
    // ===================================
    
    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             (data.email == null || (data.email is string && data.email.size() <= 200)) &&
             data.name is string && data.name.size() <= 100 &&
             data.role in ['user', 'admin', 'guest'] &&
             data.keys().hasAll(['uid', 'name', 'role']) && 
             data.keys().size() <= 15;
    }

    function isValidOrder(data) {
      return data.userId == request.auth.uid &&
             data.products is list && data.products.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.status in ['Placed', 'Packing', 'Out for Delivery', 'Delivered', 'Failed', 'Cancelled'] &&
             data.address is string && data.address.size() <= 500 &&
             data.phone is string && data.phone.size() <= 20 &&
             data.keys().hasAll(['userId', 'products', 'total', 'status', 'address', 'phone']);
    }

    // ===================================
    // COLLECTIONS
    // ===================================

    match /users/{userId} {
      // Identity & Admin access
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isOwner(userId) && isValidUser(incoming());
      
      allow update: if (isOwner(userId) || isAdmin()) && (
        // Action: User Profile Update
        (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email', 'updatedAt', 'phone', 'address', 'role']) && 
         incoming().uid == userId &&
         (isAdmin() || 
          incoming().role == existing().role || 
          (existing().role == 'guest' && incoming().role == 'user'))) ||
        // Action: Admin Override
        isAdmin()
      );
      
      allow delete: if isAdmin();
    }

    match /collections/{collectionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() || (
        // Allow stock deduction during checkout
        isSignedIn() && 
        incoming().diff(existing()).affectedKeys().hasOnly(['variants'])
      );
    }

    match /orders/{orderId} {
      allow create: if isValidId(orderId) && isSignedIn() && isValidOrder(incoming());
      
      // Secure list/get queries (Pillar 8)
      allow list: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow get: if isValidId(orderId) && isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      
      allow update: if isValidId(orderId) && (isAdmin() || (
        // User Action: Cancel Order
        isSignedIn() && resource.data.userId == request.auth.uid && 
        incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
        incoming().status == 'Cancelled' &&
        existing().status == 'Placed'
      ));
      
      allow delete: if isValidId(orderId) && isAdmin();
    }

    match /wishlists/{userId} {
      allow read: if isValidId(userId) && isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isValidId(userId) && isSignedIn() && request.auth.uid == userId;
    }

    // Connection test document
    match /test/connection {
      allow read: if true;
    }
  }
}
