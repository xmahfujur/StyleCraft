rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (matches auth.uid)
    // Fields:
    //   - uid: string (required)
    //   - name: string (required)
    //   - email: string (required)
    //   - role: string (optional, 'user' or 'admin')
    //
    // Collection: products
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - price: number (required)
    //   - image: string (required)
    //   - category: string (required)
    //   - description: string (optional)
    //
    // Collection: orders
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required)
    //   - products: list (required)
    //   - total: number (required)
    //   - status: string (required)
    //   - address: string (required)
    //   - phone: string (required)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (
          request.auth.token.email == "samimolla629@gmail.com" ||
          request.auth.token.email == "mr074770@gmail.com" ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             (!('email' in data) || data.email == null || (data.email is string && data.email.size() < 150));
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'images', 'category', 'description', 'deliveryType', 'insideDhaka', 'outsideDhaka']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.price is number && data.price >= 0 &&
             data.images is list && data.images.size() <= 4 &&
             data.category is string && data.category.size() > 0 && data.category.size() < 50 &&
             data.description is string && data.description.size() < 2000 &&
             data.deliveryType in ['Free', 'Paid'] &&
             data.insideDhaka is number && data.insideDhaka >= 0 &&
             data.outsideDhaka is number && data.outsideDhaka >= 0;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'products', 'total', 'status', 'address', 'createdAt', 'phone']) &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 100 &&
             data.products is list && data.products.size() > 0 && data.products.size() < 50 &&
             data.total is number && data.total >= 0 &&
             data.status in ['Placed', 'Packing', 'Out for Delivery', 'Delivered', 'Failed'] &&
             data.address is string && data.address.size() > 0 && data.address.size() < 500 &&
             data.phone is string && data.phone.size() > 0 && data.phone.size() < 20 &&
             (!('createdAtISO' in data) || data.createdAtISO is string) &&
             (!('deliveryCharge' in data) || data.deliveryCharge is number) &&
             (!('location' in data) || data.location in ['Inside Dhaka', 'Outside Dhaka']) &&
             (!('invoicePrinted' in data) || data.invoicePrinted is bool) &&
             (!('invoicePrintedAt' in data) || data.invoicePrintedAt is string);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      // Allow admins to list all orders, regular users can only list their own
      allow list: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow get: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidOrder(request.resource.data);
      allow update: if isAdmin() && isValidOrder(request.resource.data);
      allow delete: if isAdmin() && (resource.data.status == 'Delivered' || resource.data.status == 'Failed');
    }
  }
}
