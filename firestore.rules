rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===================================
    // GLOBAL HELPERS
    // ===================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (
          request.auth.token.email == "samimolla629@gmail.com" ||
          request.auth.token.email == "mr074770@gmail.com" ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    // ===================================
    // COLLECTION: ORDERS
    // ===================================
    match /orders/{orderId} {
      // Create allows any authenticated user (registered or guest)
      allow create: if isAuthenticated();
      
      // Admins see all, users see their own
      allow list, get: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      
      // Only admins can update (status changes) or delete
      allow update: if isAdmin();
      allow delete: if isAdmin() && (resource.data.status == 'Delivered' || resource.data.status == 'Failed');
    }

    // ===================================
    // COLLECTION: USERS
    // ===================================
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // ===================================
    // COLLECTION: PRODUCTS
    // ===================================
    match /products/{productId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        isAuthenticated() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['variants'])
      );
    }

    // ===================================
    // COLLECTION: CATEGORIES
    // ===================================
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
