{
  "entities": {
    "user": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["user", "admin"] }
      },
      "required": ["uid", "name", "email"]
    },
    "product": {
      "title": "Product",
      "description": "Clothing product details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string" },
        "category": { "type": "string", "enum": ["Shirts", "Pants"] },
        "description": { "type": "string" }
      },
      "required": ["name", "price", "image", "category"]
    },
    "order": {
      "title": "Order",
      "description": "Customer order record",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "products": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["Placed", "Packing", "Out for Delivery", "Delivered", "Failed"] },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "products", "total", "status", "address", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "user",
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": "product",
      "description": "Product catalog"
    },
    "/orders/{orderId}": {
      "schema": "order",
      "description": "Customer orders"
    }
  }
}
